{
  "name": "ReefTycoonTests",
  "tree": {
    "$className": "DataModel",

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "ReefTycoon": {
        "$className": "Folder",
        "Services": {
          "$path": "src/server/Services"
        }
      },
      "Tests": {
        "$path": "tests"
      }
    },

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Shared": {
        "$path": "src/shared"
      }
    },

    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "FilteringEnabled": true,
        "StreamingEnabled": false
      }
    }
  }
}
